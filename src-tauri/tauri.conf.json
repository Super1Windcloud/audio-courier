{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Audio Courier",
  "version": "1.0.5",
  "identifier": "com.superwindcloud.audio-courier",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Audio Courier",
        "width": 800,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "transparent": true,
        "visible": false,
        "contentProtected": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "decorations": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY3MjkyOUVDNkJGQUI1QwpSV1JjcTcvR25wSnlCaHZmQ0VPendZUDVETkRkZnJ6cm8vVUdNVzBOdlNWYVNmcC8vUVVvU09pOQo=",
      "endpoints": [
        "https://raw.githubusercontent.com/Super1Windcloud/audio-courier/main/updater/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
