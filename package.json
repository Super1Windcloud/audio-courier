{
  "name": "audio-courier",
  "private": true,
  "version": "1.0.6",
  "type": "module",
  "author": "superwindcloud",
  "license": "Apache-2.0",
  "homepage": "https://github/super1windcloud/audio-courier",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "taze": "npx taze latest -w",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "td": "pnpm tauri dev",
    "tb": "pnpm tauri build",
    "dry:tb": "pnpm  tauri build --no-bundle",
    "release:build": "tsx scripts/release.ts build",
    "release:publish": "tsx scripts/release.ts publish",
    "release": "tsx scripts/release.ts",
    "clean": "cd src-tauri && cargo clean",
    "check": "biome check src  --write",
    "lint": "eslint  src  --fix --max-warnings=0",
    "format": "pnpm --stream --color \"/format:/\"",
    "format:rs": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:js": "biome format src  --write",
    "generate:icons": "tauri icon  app-icon.png",
    "generate:signkey": "tauri signer generate -w .tauri/${npm_package_name}_signer.key",
    "prepare": "husky",
    "migrate": "biome migrate eslint --write",
    "fix": "biome check --write",
    "bump": "tsx scripts/bump-version.ts"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-global-shortcut": "~2.3.1",
    "@tauri-apps/plugin-log": "~2.8.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "openai": "^6.33.0",
    "opencc-js": "^1.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "rm": "^0.1.8",
    "sonner": "^2.0.7",
    "styled-components": "^6.3.12",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.0",
    "@types/opencc-js": "^1.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "baseline-browser-mapping": "^2.10.11",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "ws": "^8.20.0"
  }
}
